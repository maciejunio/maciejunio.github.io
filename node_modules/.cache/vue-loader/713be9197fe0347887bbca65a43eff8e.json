rzyłem\n        własną działalność gospodarczą, aby móc pracować również jako\n        freelancer. Ukończyłem studia inżynierskie pierwszego stopnia z\n        informatyki. Moja praca inżynierska nosiła tytuł \"Analiza możliwości\n        zastosowania rozwiązań IoT dla potrzeb controlingu parkingu miejskiego\".\n        W wolnym czasie rozwijam swoje umiejętności w zakresie tworzenia\n        aplikacji internetowych.\n      </p>\n    </div>\n\n    <div class=\"contact\">\n      <div class=\"row\">\n        <div class=\"col-md-4 col-sm-6\">\n          <div class=\"item\">\n            <Phone :size=\"35\" fillColor=\"#d0bb79\" />\n            <div>\n              <h6>Telefon</h6>\n              <p @click=\"showPhone\">{{ phone }}</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-4 col-sm-6\">\n          <div class=\"item\">\n            <At :size=\"35\" fillColor=\"#d0bb79\" />\n            <div>\n              <h6>Email</h6>\n              <p @click=\"showEmail\">{{ email }}</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-4 col-sm-6\">\n          <div class=\"item\">\n            <MapMarker :size=\"35\" fillColor=\"#d0bb79\" />\n            <div>\n              <h6>Lokalizacja</h6>\n              <p>Sosnowiec, Śląsk</p>\n            </div>\n          </div>\n        </div>\n        <div class=\"col-md-4 col-sm-6\"></div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport Phone from 'vue-material-design-icons/Phone.vue';\nimport At from 'vue-material-design-icons/At.vue';\nimport MapMarker from 'vue-material-design-icons/MapMarker.vue';\nexport default {\n  components: {\n    Phone,\n    At,\n    MapMarker,\n  },\n  data() {\n    return {\n      email: 'maci**.gorn***i96@gmail.com',\n      phone: '51* *** 629',\n    };\n  },\n  methods: {\n    showEmail() {\n      this.email = 'maciej.gornicki96@gmail.com';\n    },\n    showPhone() {\n      this.phone = '517 319 629';\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.About {\n  .aboutMeText {\n    h5 {\n      color: #eee;\n      font-weight: 600;\n      line-height: 1.6;\n      margin-bottom: 15px;\n      font-size: 24px;\n    }\n    p {\n      font-size: 17px;\n      font-weight: 400;\n      font-family: 'Open Sans', sans-serif;\n      color: #999;\n      line-height: 2;\n      margin: 0;\n      text-align: justify;\n    }\n  }\n\n  .contact {\n    padding: 40px 15px;\n    border-radius: 10px;\n    background: #12141c;\n    margin: 80px 0;\n    text-align: center;\n    .item {\n      h6 {\n        margin-top: 20px;\n        font-size: 17px;\n        text-transform: uppercase;\n      }\n      p {\n        font-size: 16px;\n        color: #ccc;\n        cursor: pointer;\n        transition: all 0.2s ease-in;\n        &:hover {\n          color: rgb(238, 238, 238);\n        }\n      }\n    }\n  }\n}\n</style>\n"]}]}